POSTGRES_USER=trillia
POSTGRES_PASSWORD=trillia
POSTGRES_DB=trillia

TRILLIA_DATABASE_URL=postgresql+asyncpg://trillia:trillia@db:5432/trillia
TRILLIA_MONITORED_PAIRS=BRL-USD,BRL-EUR,BRL-ARS,BRL-UYU,USD-BRL,USD-EUR,USD-ARS,USD-UYU
TRILLIA_POLLING_INTERVAL_SECONDS=30
TRILLIA_AWESOMEAPI_BASE_URL=https://economia.awesomeapi.com.br
TRILLIA_PROVIDER_TIMEOUT_SECONDS=5
TRILLIA_PROVIDER_RETRY_ATTEMPTS=4
TRILLIA_LOG_LEVEL=INFO
TRILLIA_LOG_JSON=true
TRILLIA_CORS_ALLOW_ORIGINS=["http://localhost:5173","http://localhost:8080"]
TRILLIA_ENVIRONMENT=development

VITE_API_BASE_URL=http://localhost:8000

# Airflow (LocalExecutor) — orchestrates polling (replaces the APScheduler worker)
# Airflow UI: http://localhost:8081  (login admin / admin)
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
